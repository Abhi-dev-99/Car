{
  "name": "autovahan",
  "private": true,
  "version": "1.0.0",
  "description": "AutoVahan - India's Premium Car Showroom (Monorepo)",
  "workspaces": [
    "fn",
    "bn"
  ],
  "scripts": {
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"blue,green\" \"npm run dev --workspace=bn\" \"npm run dev --workspace=fn\"",
    "dev:fn": "npm run dev --workspace=fn",
    "dev:bn": "npm run dev --workspace=bn",
    "build": "npm run build --workspace=fn && npm run build --workspace=bn",
    "build:fn": "npm run build --workspace=fn",
    "build:bn": "npm run build --workspace=bn",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
